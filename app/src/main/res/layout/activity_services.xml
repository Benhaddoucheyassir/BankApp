<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/marge_large"
        android:text="Services"
        android:textColor="@color/primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnAppeler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/marge_standard"
        android:text="Appeler la banque" />

    <Button
        android:id="@+id/btnSms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/marge_standard"
        android:layout_marginEnd="@dimen/marge_standard"
        android:layout_marginBottom="@dimen/marge_standard"
        android:text="Envoyer un SMS" />

    <Button
        android:id="@+id/btnEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/marge_standard"
        android:layout_marginEnd="@dimen/marge_standard"
        android:layout_marginBottom="@dimen/marge_standard"
        android:text="Envoyer un email" />

    <Button
        android:id="@+id/btnLocaliser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/marge_standard"
        android:layout_marginEnd="@dimen/marge_standard"
        android:text="Localiser l'agence" />

</LinearLayout>